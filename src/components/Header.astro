---
import { site } from '../data/site';
import { navLinks } from '../data/nav';
import Icon from './Icon.astro';
import Logo from './Logo.astro';

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class:list={['header', { 'header--transparent': transparent }]} data-header>
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="Accueil — Courtin Bat, plombier chauffagiste">
      <Logo size={42} />
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      {navLinks.map((l) => (
        <a
          href={l.href}
          class:list={['header__link', { 'is-active': current === l.href.replace(/\/$/, '') }]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="header__actions">
      <a href={site.phoneHref} class="header__phone" data-track="call_header" aria-label={`Appeler Courtin Bat au ${site.phone}`}>
        <span class="header__phone-icon"><Icon name="phone" /></span>
        <span class="header__phone-copy">
          <span class="header__phone-label">Appelez-nous</span>
          <span class="header__phone-number">{site.phone}</span>
        </span>
      </a>
      <a href="/contact" class="btn btn--primary header__cta" data-track="quote_header">Demander un devis</a>
      <button
        class="header__burger"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Ouvrir le menu"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.4s var(--ease), box-shadow 0.4s var(--ease),
      backdrop-filter 0.4s var(--ease);
    background: transparent;
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--header-h);
  }
  .header__logo {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }
  /* Texte du logo en blanc quand le header est transparent (hero sombre) ;
     la pastille blanche autour de l'icône est gérée plus bas. */
  .header--transparent:not(.scrolled) .header__logo { color: #fff; }

  /* État non scrollé : fond clair par défaut (pages sans hero sombre) */
  .header:not(.header--transparent) {
    background: rgba(245, 245, 246, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  /* Glassmorphism au scroll */
  .header.scrolled {
    background: var(--glass-bg);
    backdrop-filter: blur(16px) saturate(140%);
    box-shadow: var(--shadow-sm);
    border-bottom: 1px solid var(--glass-border);
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }
  .header__link {
    padding: 0.5rem 0.7rem;
    border-radius: 10px;
    font-size: 0.93rem;
    font-weight: 500;
    color: var(--ink-2);
    transition: color 0.25s, background-color 0.25s;
  }
  .header__link:hover { color: var(--ink); background: rgba(47,77,104,0.06); }
  .header__link.is-active { color: var(--steel); font-weight: 600; }
  .header--transparent:not(.scrolled) .header__link { color: rgba(255,255,255,0.84); }
  .header--transparent:not(.scrolled) .header__link:hover {
    color: #fff;
    background: rgba(255,255,255,0.1);
  }
  .header--transparent:not(.scrolled) .header__link.is-active { color: #fff; }
  /* État scrollé (verre clair) : texte foncé garanti, même sur page à hero sombre */
  .header.scrolled .header__link { color: var(--ink-2); }
  .header.scrolled .header__link:hover { color: var(--ink); }
  .header.scrolled .header__link.is-active { color: var(--steel); }
  .header.scrolled .header__phone { color: var(--steel-deep); }
  .header.scrolled .header__phone-icon { background: var(--copper); color: #fff; }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .header__phone {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-head);
    font-weight: 700;
    color: var(--steel-deep);
    min-height: 48px;
    padding: 0.38rem 0.85rem 0.38rem 0.42rem;
    border-radius: 999px;
    background: rgba(176, 106, 60, 0.12);
    border: 1px solid rgba(176, 106, 60, 0.32);
    box-shadow: 0 10px 24px rgba(176, 106, 60, 0.14);
    transition: transform var(--dur) var(--ease), background-color var(--dur) var(--ease),
      color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .header__phone:hover {
    color: #fff;
    background: var(--copper);
    box-shadow: 0 14px 30px rgba(176, 106, 60, 0.26);
    transform: translateY(-1px);
  }
  .header__phone-icon {
    position: relative;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    flex: 0 0 36px;
    border-radius: 50%;
    background: var(--copper);
    color: #fff;
  }
  .header__phone-icon::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    border: 1px solid rgba(176, 106, 60, 0.5);
    animation: callPulse 2.2s ease-out infinite;
  }
  .header__phone-icon :global(.cb-i) {
    width: 19px;
    height: 19px;
    transform-origin: center;
    animation: callWiggle 3.8s ease-in-out infinite;
  }
  .header__phone-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.05;
  }
  .header__phone-label {
    color: var(--copper);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0;
  }
  .header__phone-number {
    font-size: 0.98rem;
    font-weight: 800;
    white-space: nowrap;
  }
  .header__phone:hover .header__phone-icon {
    background: #fff;
    color: var(--copper);
  }
  .header__phone:hover .header__phone-label { color: rgba(255,255,255,0.86); }
  .header--transparent:not(.scrolled) .header__phone {
    color: #fff;
    background: rgba(176, 106, 60, 0.96);
    border-color: rgba(255,255,255,0.36);
    box-shadow: 0 16px 34px rgba(0,0,0,0.22);
  }
  .header--transparent:not(.scrolled) .header__phone-label { color: rgba(255,255,255,0.86); }
  .header--transparent:not(.scrolled) .header__phone-icon {
    background: #fff;
    color: var(--copper);
  }
  .header--transparent:not(.scrolled) .header__phone-icon::before {
    border-color: rgba(255,255,255,0.62);
  }

  .header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px; height: 44px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0 11px;
  }
  .header__burger span {
    display: block; height: 2px;
    background: var(--steel-deep);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .header--transparent:not(.scrolled) .header__burger {
    border-color: rgba(255,255,255,0.42);
  }
  .header--transparent:not(.scrolled) .header__burger span {
    background: #fff;
  }

  /* Gestion du menu ouvert sur mobile : le header doit passer en mode clair */
  :global(body.menu-open) .header {
    background: var(--glass-bg) !important;
    backdrop-filter: blur(16px) saturate(140%) !important;
    border-bottom: 1px solid var(--glass-border) !important;
  }
  :global(body.menu-open) .header__logo { color: var(--ink) !important; }
  :global(body.menu-open) .header__burger span { background: var(--steel-deep) !important; }
  :global(body.menu-open) .header__logo :global(.logo) {
    background: transparent !important;
    padding: 0 !important;
    box-shadow: none !important;
  }

  /* Animation du logo du header au chargement */
  .header__logo {
    animation: fadeLogoIn 0.8s ease-out forwards;
  }

  @keyframes fadeLogoIn {
    0% { opacity: 0; transform: translateY(-10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes callPulse {
    0% { opacity: 0.7; transform: scale(0.82); }
    70%, 100% { opacity: 0; transform: scale(1.35); }
  }
  @keyframes callWiggle {
    0%, 72%, 100% { transform: rotate(0deg); }
    76% { transform: rotate(-12deg); }
    80% { transform: rotate(10deg); }
    84% { transform: rotate(-8deg); }
    88% { transform: rotate(6deg); }
    92% { transform: rotate(0deg); }
  }

  @media (max-width: 1120px) {
    .header__nav { display: none; }
  }
  @media (max-width: 768px) {
    .header__cta { display: none; }
    .header__burger { display: flex; }
  }
  @media (max-width: 560px) {
    .header__logo :global(.logo__text) { display: none; }
    .header__phone {
      min-height: 44px;
      padding: 0.34rem 0.68rem 0.34rem 0.36rem;
    }
    .header__phone-icon {
      width: 33px;
      height: 33px;
      flex-basis: 33px;
    }
    .header__phone-number { display: none; }
    .header__phone-label { font-size: 0.84rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .header__phone-icon::before,
    .header__phone-icon :global(.cb-i) {
      animation: none;
    }
  }
</style>
