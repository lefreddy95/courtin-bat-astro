---
import { site } from '../data/site';
import Icon from './Icon.astro';
import AmbientFx from './AmbientFx.astro';

interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Un projet, une panne, une question ?',
  text = 'Contactez Courtin Bat pour un conseil clair et un devis transparent. Une approche sérieuse, transparente et rassurante, du diagnostic à la finition.',
} = Astro.props;
---
<section class="section cta-band surface-dark" data-drop-reveal>
  <AmbientFx theme="mix" />
  <div class="container cta-band__inner">
    <div>
      <span class="eyebrow">Contact</span>
      <h2>{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="cta-band__actions">
      <a href={site.phoneHref} class="btn btn--copper btn--lg" data-track="call_cta">
        <Icon name="phone" /> {site.phone}
      </a>
      <a href="/contact" class="btn btn--light btn--lg" data-track="quote_cta">Demander un devis</a>
    </div>
  </div>
</section>

<style>
  .cta-band { overflow: hidden; }
  .cta-band__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    align-items: center;
    gap: 2rem;
  }
  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: flex-end;
  }
  @media (max-width: 820px) {
    .cta-band__inner { grid-template-columns: 1fr; }
    .cta-band__actions { justify-content: flex-start; }
  }
</style>
