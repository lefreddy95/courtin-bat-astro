---
/**
 * Animation signature : le logo COURTIN BAT (anneau C + robinet) avec une goutte
 * qui se forme au bout du bec, tombe et vient onduler la vague d'eau.
 * - GSAP anime [data-drop] si JS actif ; sinon animation CSS de secours.
 * - Désactivée via prefers-reduced-motion.
 * Sur le hero (fond sombre), l'encre est blanche, l'eau reste bleue.
 */
---
<div class="logo-anim" data-hero-logo aria-hidden="true">
  <svg viewBox="0 0 520 620" xmlns="http://www.w3.org/2000/svg" class="logo-anim__svg">
    <!-- Anneau C -->
    <path d="M424 440 A205 205 0 1 1 424 204" fill="none" stroke="currentColor" stroke-width="70" stroke-linecap="round"/>
    <!-- Robinet -->
    <g fill="currentColor">
      <rect x="345" y="92" width="34" height="30" rx="12"/>
      <rect x="290" y="118" width="144" height="36" rx="18"/>
      <rect x="350" y="150" width="24" height="24"/>
      <rect x="310" y="170" width="104" height="32" rx="8"/>
      <rect x="338" y="200" width="48" height="60"/>
      <rect x="298" y="246" width="128" height="78" rx="12"/>
      <rect x="188" y="256" width="130" height="58" rx="6"/>
      <rect x="172" y="246" width="36" height="78" rx="14"/>
      <path d="M388 300 L470 300 Q500 300 500 342 L500 378 L452 378 L452 348 Q452 324 424 324 L388 324 Z"/>
      <rect x="446" y="372" width="66" height="28" rx="13"/>
    </g>
    <!-- Vague d'eau -->
    <path class="logo-anim__wave" d="M150 432 C196 414 236 452 286 440 C332 429 374 458 420 442 C442 434 462 432 472 446 L472 470 C470 506 452 548 430 562 C419 542 414 520 404 506 C360 520 300 514 250 502 C210 493 175 472 150 470 Z"/>
    <!-- Onde d'impact dans la vague -->
    <ellipse class="logo-anim__ripple" cx="455" cy="452" rx="8" ry="3" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="3"/>
    <!-- Goutte animée (part du bec) -->
    <path data-drop class="logo-anim__drop" d="M479 404 C497 430 508 444 508 460 a29 29 0 1 1 -58 0 C450 444 461 430 479 404 Z"/>
  </svg>
</div>

<style>
  .logo-anim {
    width: min(380px, 76vw);
    margin-inline: auto;
    color: #fff; /* encre blanche sur le hero sombre */
    filter: drop-shadow(0 30px 50px rgba(8, 22, 36, 0.45));
  }
  .logo-anim__svg { width: 100%; height: auto; overflow: visible; }
  .logo-anim__wave { fill: #2a93d6; }
  .logo-anim__drop { fill: #cfe6f6; transform-origin: 479px 404px; }

  /* --- Fallback CSS (sans GSAP) --- */
  .js .logo-anim__drop { opacity: 0; }
  html:not(.js) .logo-anim__drop {
    animation: drop-fall 3s var(--ease) infinite;
  }
  html:not(.js) .logo-anim__ripple {
    animation: ripple 3s var(--ease) infinite;
    transform-origin: 455px 452px;
  }

  @keyframes drop-fall {
    0%, 15% { opacity: 0; transform: translateY(0) scale(0.5); }
    30% { opacity: 1; transform: translateY(0) scale(1); }
    70% { opacity: 1; transform: translateY(46px) scale(1); }
    80% { opacity: 0; transform: translateY(56px) scaleX(1.6) scaleY(0.4); }
    100% { opacity: 0; }
  }
  @keyframes ripple {
    0%, 70% { opacity: 0; transform: scale(0.4); }
    82% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.6); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-anim__drop { opacity: 1 !important; animation: none !important; }
    .logo-anim__ripple { display: none; }
  }
</style>
