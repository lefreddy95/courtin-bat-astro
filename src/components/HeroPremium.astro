---
import { site } from '../data/site';
import Icon from './Icon.astro';
import LogoWaterAnimation from './LogoWaterAnimation.astro';

const badges = ['Artisan qualifié', 'Intervention locale', 'Devis clair', 'Travail soigné', 'Plomberie & chauffage'];
---
<section class="hero" id="hero" data-water-scope-start>
  <!-- Fond premium : vidéo cinématique locale + overlays thématiques -->
  <div class="hero__bg" id="hero-bg" aria-hidden="true">
    <video class="hero__video" autoplay muted loop playsinline preload="auto">
      <source src="/assets/cinematique-courtin-bat.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>
    <div class="hero__glow hero__glow--1"></div>
    <div class="hero__glow hero__glow--2"></div>
    <div class="hero__glow hero__glow--3"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="reveal-wrap">
        <span class="badge badge--glass hero__tag reveal-item"><Icon name="award" /> Plombier chauffagiste diplômé</span>
      </div>
      
      <h1 class="hero__title">
        <span class="reveal-wrap"><span class="reveal-item block">Courtin&nbsp;Bat,</span></span>
        <span class="reveal-wrap"><span class="reveal-item block text-gradient">artisan d'excellence</span></span>
        <span class="reveal-wrap"><span class="reveal-item block">dans le Vexin & Val-d'Oise.</span></span>
      </h1>
      
      <div class="reveal-wrap">
        <p class="hero__subtitle reveal-item">
          Dépannage, installation, rénovation sanitaire et chauffage avec un travail propre,
          durable et réalisé dans les règles de l’art.
        </p>
      </div>

      <div class="reveal-wrap">
        <div class="hero__actions reveal-item">
          <a href="/contact" class="btn btn--copper btn--lg" data-track="quote_hero">Demander un devis</a>
          <a href={site.phoneHref} class="btn btn--glass btn--lg" data-track="call_hero">
            <Icon name="phone" /> Appeler maintenant
          </a>
        </div>
      </div>

    </div>

    <div class="hero__visual reveal-item-visual">
      <LogoWaterAnimation />
    </div>
  </div>
</section>

<!-- Barre des pastilles sous le hero -->
<section class="badges-banner" aria-label="Atouts de l'entreprise">
  <div class="container badges-banner__inner">
    {badges.map((b) => (
      <span class="badge badge--outline"><Icon name="check" /> {b}</span>
    ))}
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Parallax background effect
    gsap.to("#hero-bg", {
      yPercent: 30,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });

    // Master Timeline for smooth, cinematic entrance
    const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.4 } });

    // Initial state
    gsap.set(".reveal-item", { y: 80, opacity: 0 });
    gsap.set(".reveal-item-visual", { scale: 0.9, opacity: 0, filter: "blur(10px)" });

    tl.to(".reveal-item", {
      y: 0,
      opacity: 1,
      stagger: 0.15,
      delay: 0.1
    })
    .to(".reveal-item-visual", {
      scale: 1,
      opacity: 1,
      filter: "blur(0px)",
      duration: 1.8,
      ease: "power3.out"
    }, "-=1.2");
  });
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #0b1118;
    color: #fff;
    padding-top: clamp(3rem, 8vh, 6rem);
    padding-bottom: clamp(3.5rem, 9vh, 7rem);
    margin-top: calc(-1 * var(--header-h));
    padding-top: calc(var(--header-h) + clamp(2rem, 6vh, 4rem));
    min-height: max(80vh, 600px);
    display: flex;
    align-items: center;
    /* Le hero est déjà pleine largeur (bloc enfant de <main>, sans padding).
       On évite 100vw qui, avec une scrollbar classique, déborde de ~18px
       et décale le hero par rapport aux autres sections. */
    width: 100%;
  }
  
  .hero__bg {
    position: absolute;
    inset: -15% 0; /* Parallax vertical uniquement */
    z-index: 0;
    height: 130%;
    width: 100%;
    /* Isole le fond sur sa propre couche GPU : le parallax ne repeint plus la vidéo */
    will-change: transform;
    transform: translateZ(0);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background: #000;
    /* Lecture vidéo accélérée par le GPU, sans repaint pendant le scroll */
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to right, rgba(11, 17, 24, 0.82) 0%, rgba(11, 17, 24, 0.45) 48%, rgba(11, 17, 24, 0.12) 100%),
      linear-gradient(to bottom, rgba(11, 17, 24, 0.5) 0%, rgba(11, 17, 24, 0) 22%, rgba(11, 17, 24, 0) 72%, rgba(11, 17, 24, 0.82) 100%),
      radial-gradient(120% 90% at 50% 35%, transparent 60%, rgba(6, 10, 15, 0.4) 100%);
  }

  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    z-index: 2;
    animation: float 14s ease-in-out infinite;
    will-change: transform;
    transform: translateZ(0);
  }
  .hero__glow--1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #4f7da3, transparent 70%);
    top: -10%; right: -10%;
  }
  .hero__glow--2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #b8860b, transparent 70%);
    bottom: -10%; left: -10%;
    animation-delay: -7s;
  }
  .hero__glow--3 {
    width: 360px; height: 360px;
    background: radial-gradient(circle, #38bdf8, transparent 70%);
    top: 35%; left: 30%;
    opacity: 0.22;
    animation-delay: -3.5s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-40px) scale(1.05); }
  }

  .hero__inner {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr; /* Mieux équilibré pour centrer le logo */
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    width: 100%;
  }

  .reveal-wrap {
    overflow: hidden;
    padding-bottom: 0.2rem;
  }
  .block { display: block; }

  .hero__tag { margin-bottom: 1.4rem; }
  
  .hero__title {
    color: #fff;
    margin-bottom: 1.2rem;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  
  .text-gradient {
    background: linear-gradient(135deg, #fff 0%, #d4af37 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 54ch;
    margin-bottom: 2.2rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    /* Le margin-bottom a été retiré pour recentrer verticalement le bloc */
  }

  .badge--glass, .btn--glass {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    transition: all 0.3s ease;
  }
  .btn--glass:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .badge--glass {
    padding: 0.5em 1em;
    border-radius: 100px;
  }

  .hero__visual { 
    display: flex; 
    justify-content: center; 
    position: relative;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.4));
  }
  
  /* CSS pour la nouvelle barre sous le hero */
  .badges-banner {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    padding: 1.2rem 0;
  }
  .badges-banner__inner {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 2.5rem;
  }
  .badge--outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--ink-2);
    font-weight: 500;
  }
  .badge--outline :global(svg) {
    color: var(--copper);
    width: 18px;
    height: 18px;
  }

  @media (max-width: 992px) {
    .hero__inner { grid-template-columns: 1fr; text-align: center; }
    .hero__title { max-width: none; }
    .hero__subtitle { max-width: none; margin-left: auto; margin-right: auto; }
    .hero__actions { justify-content: center; }
    .hero__overlay {
      background:
        linear-gradient(to bottom, rgba(11, 17, 24, 0.55) 0%, rgba(11, 17, 24, 0.35) 45%, rgba(11, 17, 24, 0.88) 100%);
    }
    .hero__visual { display: none; }
  }

  @media (max-width: 600px) {
    .badges-banner__inner { gap: 0.8rem 1.2rem; justify-content: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__glow { animation: none; }
  }
</style>
