---
import { site } from '../data/site';
import Icon from './Icon.astro';
import LogoWaterAnimation from './LogoWaterAnimation.astro';

const badges = ['Artisan qualifié', 'Intervention locale', 'Devis clair', 'Travail soigné', 'Plomberie & chauffage'];
---
<section class="hero" data-water-scope-start>
  <!-- Fond premium : dégradé animé léger + vidéo optionnelle -->
  <div class="hero__bg" aria-hidden="true">
    <!--
      Pour ajouter une vidéo cinématique, placer le fichier dans /public/assets/
      et décommenter le bloc ci-dessous (fallback gradient conservé).
    -->
    <!--
    <video class="hero__video" autoplay muted loop playsinline poster="/assets/images/hero-poster.jpg">
      <source src="/assets/hero.mp4" type="video/mp4" />
    </video>
    -->
    <div class="hero__glow hero__glow--1"></div>
    <div class="hero__glow hero__glow--2"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <span class="badge badge--light hero__tag"><Icon name="award" /> Plombier chauffagiste diplômé</span>
      <h1 class="hero__title">
        Courtin&nbsp;Bat, artisan plombier chauffagiste dans le Vexin et le Val-d’Oise
      </h1>
      <p class="hero__subtitle">
        Dépannage, installation, rénovation sanitaire et chauffage avec un travail propre,
        durable et réalisé dans les règles de l’art.
      </p>

      <div class="hero__actions">
        <a href="/contact" class="btn btn--copper btn--lg" data-track="quote_hero">Demander un devis</a>
        <a href={site.phoneHref} class="btn btn--light btn--lg" data-track="call_hero">
          <Icon name="phone" /> Appeler maintenant
        </a>
        <a href="/qualifications" class="btn btn--light btn--lg" data-track="qualif_hero">Voir nos qualifications</a>
      </div>

      <ul class="hero__badges badges">
        {badges.map((b) => (
          <li class="badge badge--light"><Icon name="check" /> {b}</li>
        ))}
      </ul>
    </div>

    <div class="hero__visual">
      <LogoWaterAnimation />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--grad-hero);
    color: #fff;
    padding-top: clamp(3rem, 8vh, 6rem);
    padding-bottom: clamp(3.5rem, 9vh, 7rem);
    margin-top: calc(-1 * var(--header-h));
    padding-top: calc(var(--header-h) + clamp(2rem, 6vh, 4rem));
  }
  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__video {
    width: 100%; height: 100%; object-fit: cover; opacity: 0.35;
  }
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.5;
    animation: float 14s ease-in-out infinite;
  }
  .hero__glow--1 {
    width: 420px; height: 420px;
    background: radial-gradient(circle, #4f7da3, transparent 70%);
    top: -120px; right: -80px;
  }
  .hero__glow--2 {
    width: 360px; height: 360px;
    background: radial-gradient(circle, #2a4a66, transparent 70%);
    bottom: -140px; left: -60px;
    animation-delay: -7s;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .hero__tag { margin-bottom: 1.4rem; }
  .hero__title {
    color: #fff;
    margin-bottom: 1.1rem;
    max-width: 16ch;
  }
  .hero__subtitle {
    font-size: clamp(1.05rem, 1.8vw, 1.28rem);
    color: rgba(255,255,255,0.85);
    max-width: 52ch;
    margin-bottom: 1.8rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 1.8rem;
  }
  .hero__badges { gap: 0.55rem; }

  .hero__visual { display: flex; justify-content: center; }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; text-align: center; }
    .hero__title, .hero__subtitle { max-width: none; }
    .hero__actions, .hero__badges { justify-content: center; }
    .hero__visual { order: -1; margin-bottom: 1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__glow { animation: none; }
  }
</style>
