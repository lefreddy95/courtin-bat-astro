---
/** Bibliothèque d'icônes SVG inline (stroke = currentColor). */
interface Props {
  name: string;
  class?: string;
}
const { name, class: className } = Astro.props;

const paths: Record<string, string> = {
  wrench:
    '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-2-2 2.6-2.6Z"/>',
  flame:
    '<path d="M12 3s4 3.5 4 8a4 4 0 0 1-8 0c0-1 .4-2 .8-2.5C9 11 12 12 12 9c0-2-2-4-2-4 .7.3 4 1.5 4 6"/><path d="M12 22a6 6 0 0 0 6-6c0-2-1-3.5-2-5"/>',
  'water-heater':
    '<rect x="6" y="3" width="12" height="14" rx="6"/><path d="M9 17v3M15 17v3M10.5 8.5a1.5 1.5 0 0 0 3 0c0-1-1.5-2.5-1.5-2.5S10.5 7.5 10.5 8.5Z"/>',
  'droplet-search':
    '<path d="M11 3s5 5.5 5 9a5 5 0 0 1-8.7 3.4"/><circle cx="6.5" cy="14.5" r="3.5"/><path d="m4 17-2 2"/>',
  shower:
    '<path d="M4 12h16M6 12V7a3 3 0 0 1 3-3h1a3 3 0 0 1 3 3"/><path d="M8 16v1M12 16v2M16 16v1M20 16v2"/>',
  climate:
    '<rect x="2" y="5" width="20" height="9" rx="2"/><path d="M6 9h.01M10 9h4M6 18c0 1 .5 2 1.5 2M11 18c0 1.5 1 2.5 2 2.5M16 18c0 1 .5 2 1.5 2"/>',
  shield:
    '<path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6l-8-3Z"/><path d="m9 12 2 2 4-4"/>',
  award:
    '<circle cx="12" cy="9" r="6"/><path d="m9 14-2 7 5-3 5 3-2-7"/>',
  ruler:
    '<path d="M3 16 16 3l5 5L8 21l-5-5Z"/><path d="M7 12l2 2M11 8l2 2M15 4l2 2"/>',
  sparkle:
    '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2 2M16 16l2 2M18 6l-2 2M8 16l-2 2"/>',
  phone:
    '<path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/>',
  arrow:
    '<path d="M5 12h14M13 6l6 6-6 6"/>',
  mail:
    '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  pin:
    '<path d="M12 21s7-5.5 7-11a7 7 0 0 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  check:
    '<path d="M20 6 9 17l-5-5"/>',
  star:
    '<path d="m12 3 2.6 5.3 5.9.9-4.2 4.1 1 5.9-5.3-2.8-5.3 2.8 1-5.9L3.5 9.2l5.9-.9L12 3Z"/>',
  graduation:
    '<path d="M12 4 2 9l10 5 10-5-10-5Z"/><path d="M6 11v5c0 1 2.7 2.5 6 2.5s6-1.5 6-2.5v-5"/>',
  tools:
    '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-2-2 2.6-2.6Z"/>',
};

const inner = paths[name] || paths['check'];
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class:list={['cb-i', className]}
  set:html={inner}
/>
