---
/**
 * Bloc de contenu SEO local (texte naturel, maillage interne).
 * Renforce le positionnement sur les requêtes "plombier Vexin / Val-d'Oise" etc.
 * sans bourrage de mots-clés.
 */
import { services } from '../data/services';
---
<section class="section local-seo">
  <div class="container local-seo__inner">
    <div data-reveal>
      <span class="eyebrow">Plombier chauffagiste local</span>
      <h2>Un artisan de proximité dans le Vexin et le Val-d’Oise</h2>
      <p>
        Vous cherchez un <strong>plombier dans le Vexin</strong> ou un
        <strong>plombier chauffagiste dans le Val-d’Oise</strong> ? Courtin Bat accompagne
        les particuliers de Magny-en-Vexin à Cergy-Pontoise pour leurs travaux de plomberie,
        de chauffage et de sanitaire, avec une intervention soignée du diagnostic à la finition.
      </p>
      <p>
        Qu’il s’agisse d’un <a href="/depannage-plomberie">dépannage de plomberie</a>, d’une
        <a href="/recherche-de-fuite">recherche de fuite</a>, du remplacement d’un
        <a href="/chauffe-eau">chauffe-eau</a>, de l’entretien de votre
        <a href="/chauffage">chauffage</a> ou de la
        <a href="/renovation-salle-de-bain">rénovation de votre salle de bain</a>, vous
        bénéficiez d’un savoir-faire professionnel et d’un conseil clair.
      </p>
    </div>

    <div class="local-seo__links card" data-reveal data-reveal-delay="120">
      <h3>Nos prestations</h3>
      <ul>
        {services.map((s) => (
          <li><a href={`/${s.slug}`}>{s.name}</a></li>
        ))}
      </ul>
      <div class="local-seo__pages">
        <a href="/plombier-vexin" class="badge">Plombier Vexin</a>
        <a href="/plombier-val-doise" class="badge">Plombier Val-d’Oise</a>
        <a href="/plombier-cergy" class="badge">Plombier Cergy</a>
        <a href="/plombier-pontoise" class="badge">Plombier Pontoise</a>
        <a href="/plombier-cergy-pontoise" class="badge">Cergy-Pontoise</a>
        <a href="/plombier-magny-en-vexin" class="badge">Magny-en-Vexin</a>
      </div>
    </div>
  </div>
</section>

<style>
  .local-seo__inner {
    display: grid;
    grid-template-columns: 1.4fr 0.9fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  .local-seo p { color: var(--ink-2); margin-bottom: 1rem; }
  .local-seo p a { color: var(--steel); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .local-seo__links h3 { margin-bottom: 0.9rem; }
  .local-seo__links ul { list-style: none; padding: 0; display: grid; gap: 0.5rem; margin-bottom: 1.2rem; }
  .local-seo__links ul a { color: var(--ink-2); }
  .local-seo__links ul a:hover { color: var(--steel); }
  .local-seo__pages { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .local-seo__pages .badge:hover { border-color: var(--steel-2); }
  @media (max-width: 820px) { .local-seo__inner { grid-template-columns: 1fr; } }
</style>
