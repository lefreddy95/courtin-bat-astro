---
/**
 * Filet d'eau SVG qui accompagne le scroll et relie les sections.
 * Le tracé se "remplit" (stroke-dashoffset) au scroll via GSAP ScrollTrigger.
 * Positionné en absolute sur toute la hauteur du conteneur [data-water-scope].
 * Décoratif : aria-hidden + caché si prefers-reduced-motion.
 */
---
<div class="water-path" data-water-path aria-hidden="true">
  <svg viewBox="0 0 100 1000" preserveAspectRatio="none" class="water-path__svg">
    <path
      d="M50 0
         C 20 90, 80 160, 50 250
         S 15 400, 50 500
         S 85 650, 50 760
         S 18 880, 50 1000"
      fill="none"
      stroke="url(#water-grad)"
      stroke-width="3"
      stroke-linecap="round"
    />
    <defs>
      <linearGradient id="water-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#7fb4dc" stop-opacity="0.9" />
        <stop offset="1" stop-color="#3a5d7c" stop-opacity="0.5" />
      </linearGradient>
    </defs>
  </svg>
</div>

<style>
  .water-path {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(120px, 30vw, 320px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }
  .water-path__svg { width: 100%; height: 100%; }

  @media (max-width: 768px) {
    .water-path { width: 80px; opacity: 0.4; left: auto; right: 1rem; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .water-path { display: none; }
  }
</style>
