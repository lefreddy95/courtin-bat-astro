---
import { site, SITE_URL } from '../data/site';
import { services } from '../data/services';
import { cities } from '../data/cities';

interface Props {
  /** Limiter l'injection des services dans le schema (page d'accueil) */
  includeServices?: boolean;
}
const { includeServices = true } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': ['Plumber', 'HVACBusiness', 'LocalBusiness'],
  '@id': `${SITE_URL}/#business`,
  name: site.name,
  description: site.description,
  url: SITE_URL,
  telephone: site.phoneHref.replace('tel:', ''),
  email: site.email,
  image: `${SITE_URL}/assets/og-courtin-bat.jpg`,
  logo: `${SITE_URL}/assets/logo-courtin-bat.svg`,
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    postalCode: site.address.postalCode,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  areaServed: [
    ...site.areaServed.map((a) => ({ '@type': 'AdministrativeArea', name: a })),
    ...cities.slice(0, 40).map((c) => ({ '@type': 'City', name: c.name })),
  ],
  openingHoursSpecification: site.openingHoursSpec.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: h.opens,
    closes: h.closes,
  })),
  ...(site.googleBusinessProfile ? { hasMap: site.googleBusinessProfile, sameAs: [site.googleBusinessProfile] } : {}),
  ...(includeServices && {
    makesOffer: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.name,
        url: `${SITE_URL}/${s.slug}`,
      },
    })),
  }),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
