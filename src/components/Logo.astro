---
interface Props {
  /** Hauteur du logo en px */
  size?: number;
  class?: string;
  showText?: boolean; // Conservé pour rétrocompatibilité au cas où, mais le nouveau logo contient tout
}
const { size = 44, class: className } = Astro.props;
---
<img 
  src="/assets/logo-courtin-bat.svg" 
  alt="Logo Courtin Bat" 
  class:list={['logo', className]} 
  style={`height: ${size}px; width: auto;`} 
  aria-label="Courtin Bat"
/>

<style>
  .logo {
    display: inline-block;
    max-width: 100%;
    object-fit: contain;
  }
</style>
